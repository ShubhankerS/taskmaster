# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://taskmaster:your-secure-password@localhost:5432/taskmaster"

# NextAuth.js v5
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Local dev:   http://localhost:3000
# Production:  https://taskmaster.shubh-lab.xyz
AUTH_URL="https://taskmaster.shubh-lab.xyz"

# GitHub OAuth App
# Create at: https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Homepage URL:      https://taskmaster.shubh-lab.xyz
# Callback URL:      https://taskmaster.shubh-lab.xyz/api/auth/callback/github
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"
